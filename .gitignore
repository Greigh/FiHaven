# FiHaven — gitignore

# ── OS & editors ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
*.tmp
*.swp
.idea/
.vscode/
.claude/

# ── Dependencies & build output ──────────────────────────────────────────────
node_modules/
node_modules/*
client/css/tailwind-built.css
dist/
coverage/

# ── Secrets & environment ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.development
# App Store Connect API keys (never commit)
*.p8
AuthKey_*.p8

# ── Deploy & ops scripts (copy from scripts/examples/) ───────────────────────
*upload.sh
scripts/rollback.sh

# Local ops credential notes (see docs/maintainer/README.md)
*.secret.md
mail-server-logins.md

# ── Local runtime data (SQLite + MFA key; created on first `npm run dev`) ───
/data/

# ── Maintainer-local docs (templates live under docs/maintainer/) ────────────
docs/local/

# ── Generated policy PDFs (source: docs/*.md — npm run generate:pdfs) ────────
docs/pdf/

# ── Android Studio inspection exports (not part of the app) ──────────────────
android/index.html
android/script.js
android/styles.css

# ── Local IDE / Play Store marketing assets (generated or machine-specific) ──
android/.run/
android/play-store/
ios/FiHavenApp/Sources/Assets.xcassets/AppIcon.appiconset/AppIcon-512.png

# ── Firecrawl scrape cache (research artifacts, not part of the app) ──────────
.firecrawl/
