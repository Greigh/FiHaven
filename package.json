{
  "name": "fihaven",
  "version": "1.3.0",
  "description": "A focused bill and debt dashboard for people who'd rather spend five calm minutes a week than a frantic afternoon every payday. Track recurring bills, credit cards (including 0% promo periods), monthly budget, payment history, and debt-payoff strategies — all behind a real account with server-side sync.",
  "license": "GNU AGPLv3",
  "author": "Greigh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Greigh/FiHaven.git"
  },
  "bugs": {
    "url": "https://github.com/Greigh/FiHaven/issues"
  },
  "homepage": "https://fihaven.app/",
  "engines": {
    "node": ">=24.16.0"
  },
  "packageManager": "npm@11.17.0",
  "type": "commonjs",
  "main": "server/index.js",
  "scripts": {
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "build:css": "tailwindcss -i ./client/css/tailwind-input.css -o ./client/css/tailwind-built.css --minify",
    "dev:css": "tailwindcss -i ./client/css/tailwind-input.css -o ./client/css/tailwind-built.css --watch",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "dev": "concurrently -k -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "build:vite": "vite build",
    "build": "npm run build:css && npm run build:vite",
    "ci": "npm run build",
    "generate:icons": "bash ./scripts/generate-icons.sh",
    "generate:pdfs": "node scripts/dev/generate-pdfs.js",
    "plaid:sandbox": "node scripts/dev/plaid-sandbox-check.js",
    "preview": "vite preview",
    "deploy": "bash upload.sh",
    "rollback": "bash scripts/examples/rollback.example.sh",
    "promo": "node scripts/promo.js",
    "indexnow": "node scripts/submit-indexnow.js"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "nodemailer": "^9.0.1",
    "otpauth": "^9.5.1",
    "plaid": "42.2.0",
    "qrcode": "1.5.4",
    "stripe": "^22.2.3"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/cli": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "10.0.3",
    "jsdom": "^29.1.1",
    "svelte": "5.56.4",
    "tailwindcss": "^4.3.1",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "bcrypt@6.0.0": true,
    "fsevents@2.3.3": true,
    "@parcel/watcher@2.5.1": true,
    "better-sqlite3@12.11.1": true
  }
}
