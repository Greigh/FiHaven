{
  "name": "fihaven",
  "version": "1.1.0",
  "description": "A focused bill and debt dashboard for people who'd rather spend five calm minutes a week than a frantic afternoon every payday. Track recurring bills, credit cards (including 0% promo periods), monthly budget, payment history, and debt-payoff strategies — all behind a real account with server-side sync.",
  "license": "GNU AGPLv3",
  "author": "Greigh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Greigh/FiHaven.git"
  },
  "bugs": {
    "url": "https://github.com/Greigh/FiHaven/issues"
  },
  "homepage": "https://fihaven.app/",
  "engines": {
    "node": ">=22.14.0"
  },
  "packageManager": "npm@11.7.0",
  "type": "commonjs",
  "main": "server/index.js",
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.js -i ./client/css/tailwind-input.css -o ./client/css/tailwind-built.css --minify",
    "dev:css": "tailwindcss -c tailwind.config.js -i ./client/css/tailwind-input.css -o ./client/css/tailwind-built.css --watch",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "dev": "concurrently -k -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "build:vite": "vite build",
    "build": "npm run build:css && npm run build:vite",
    "ci": "npm run build",
    "generate:icons": "bash ./scripts/generate-icons.sh",
    "preview": "vite preview",
    "deploy": "bash upload.sh",
    "promo": "node scripts/promo.js"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "nodemailer": "^8.0.10",
    "otpauth": "^9.5.1",
    "plaid": "^42.2.0",
    "qrcode": "^1.5.4",
    "stripe": "^22.2.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "concurrently": "^10.0.3",
    "svelte": "^5.56.1",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16"
  }
}
