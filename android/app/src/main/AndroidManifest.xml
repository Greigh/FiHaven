<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Android 13+ runtime permission to post bill-reminder notifications. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Re-arm scheduled bill reminders after a reboot. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="FiHaven"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.FiHaven">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="FiHaven"
            android:launchMode="singleTask"
            android:theme="@style/Theme.FiHaven">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Web OAuth (Apple / Google Custom Tab) returns via
                 fihaven://oauth/{apple|google}. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="fihaven" android:host="oauth" />
            </intent-filter>
        </activity>

        <!-- Fires on-device bill reminders scheduled via AlarmManager. -->
        <receiver
            android:name=".BillReminderReceiver"
            android:exported="false" />

        <!-- Re-arms persisted reminders after a reboot or app update. -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Server push via Firebase Cloud Messaging (requires google-services.json). -->
        <service
            android:name=".FcmPushService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>
</manifest>
