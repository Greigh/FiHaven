# Copy this file to .env and adjust as needed.
# In dev, .env.development is loaded first and already contains
# safe-to-commit test keys — you only need to fill in .env for
# production deploys (NODE_ENV=production).

NODE_ENV=development
PORT=5222

# Cloudflare Turnstile keys. Sign up free at
# https://dash.cloudflare.com/?to=/:account/turnstile and create
# a widget; you'll get a sitekey + secret pair.
TURNSTILE_SECRET=
TURNSTILE_SITEKEY=
# Re-expose the sitekey to Vite (same value as TURNSTILE_SITEKEY).
# Vite only reads variables prefixed with VITE_; this lets us
# inline the sitekey into login.html at build time so Turnstile
# can render immediately instead of waiting on an API round-trip.
VITE_TURNSTILE_SITEKEY=

# Session cookie name and lifetime.
SESSION_COOKIE=ct_sid
SESSION_TTL_HOURS=12

# SMTP — used to send sign-in codes for email-based MFA. In
# production the VPS runs Postfix on loopback (no auth needed).
# In dev, the server still tries to connect; either install a
# local SMTP server, set SMTP_HOST to a relay, or leave email-MFA
# disabled in the dev account.
SMTP_HOST=localhost
SMTP_PORT=25
# SMTP_USER=
# SMTP_PASS=
MAIL_FROM=FiHaven <no-reply@danielhipskind.com>

# Optional: 32-byte hex key for at-rest encryption of TOTP
# secrets. If unset, a key is auto-generated and persisted to
# data/mfa.key. Generate with: openssl rand -hex 32
# MFA_ENCRYPTION_KEY=

# ── Stripe (web premium purchases) ──────────────────────────────
# Web checkout for FiHaven Pro. The server uses STRIPE_SECRET_KEY to
# create hosted Checkout sessions and verify webhooks; the publishable
# key is exposed to the browser via /api/billing/stripe/config.
# Use sk_test_/pk_test_ keys in dev to avoid real charges — if
# STRIPE_SECRET_KEY is unset, checkout falls back to a local dev-grant.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Recurring price IDs (price_…) created under your Stripe Product
# (Billing → Products). Each plan you set a price for is offered on the
# web paywall automatically; leave a line blank to hide that plan.
# (THREE_MONTH and TRIAL are optional extra intervals.)
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
STRIPE_PRICE_THREE_MONTH=
STRIPE_PRICE_TRIAL=
# Signing secret from the webhook endpoint you register at
# {PUBLIC_ORIGIN}/fihaven/api/billing/stripe/webhook (Developers →
# Webhooks). Events: checkout.session.completed, customer.subscription.*,
# invoice.paid. If unset, webhook signatures are NOT verified (dev only).
STRIPE_WEBHOOK_SECRET=
# Public origin for Stripe success/cancel redirects (no trailing slash),
# e.g. https://fihaven.app. Falls back to the request host.
PUBLIC_ORIGIN=

# ── Plaid (optional, Pro-gated bank linking) ────────────────────
# Bank syncing is a paid convenience overlay — the app works fully by
# hand without it. Get free Sandbox credentials at
# https://dashboard.plaid.com/signup (Team Settings → Keys).
# Leave the client_id/secret blank to keep the feature off (the UI then
# shows "not available on this server"). The access_token is stored
# encrypted at rest (AES-256-GCM, same key as MFA secrets).
#
# Your client_id is the SAME across environments; the secret is
# per-environment. You can use the generic names below, OR keep both
# environments' keys side by side with PLAID_SANDBOX_SECRET /
# PLAID_PRODUCTION_SECRET — the secret matching PLAID_ENV is used.
PLAID_CLIENT_ID=
PLAID_SECRET=
# PLAID_SANDBOX_SECRET=
# PLAID_PRODUCTION_SECRET=
# 'sandbox' (default, fake banks + test creds) or 'production'.
PLAID_ENV=sandbox
# Comma-separated Plaid products + ISO country codes.
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
# Optional: public HTTPS URL Plaid posts item/transactions webhooks to,
# e.g. https://fihaven.app/api/plaid/webhook. Needed for live updates.
PLAID_WEBHOOK_URL=
# Optional: OAuth redirect URI (must be allow-listed in the Plaid
# dashboard) for banks that use an OAuth handoff.
PLAID_REDIRECT_URI=