# Copy this file to .env and adjust as needed.
# In dev, .env.development is loaded first and already contains
# safe-to-commit test keys — you only need to fill in .env for
# production deploys (NODE_ENV=production).

NODE_ENV=development
PORT=5222

# Cloudflare Turnstile keys. Sign up free at
# https://dash.cloudflare.com/?to=/:account/turnstile and create
# a widget; you'll get a sitekey + secret pair.
TURNSTILE_SECRET=
TURNSTILE_SITEKEY=
# Re-expose the sitekey to Vite (same value as TURNSTILE_SITEKEY).
# Vite only reads variables prefixed with VITE_; this lets us
# inline the sitekey into login.html at build time so Turnstile
# can render immediately instead of waiting on an API round-trip.
VITE_TURNSTILE_SITEKEY=

# Session cookie name and lifetime.
SESSION_COOKIE=ct_sid
SESSION_TTL_HOURS=12

# SMTP — used to send sign-in codes for email-based MFA. In
# production the VPS runs Postfix on loopback (no auth needed).
# In dev, the server still tries to connect; either install a
# local SMTP server, set SMTP_HOST to a relay, or leave email-MFA
# disabled in the dev account.
SMTP_HOST=localhost
SMTP_PORT=25
# SMTP_USER=
# SMTP_PASS=
MAIL_FROM=FiHaven <no-reply@fihaven.app>

# Optional: 32-byte hex key for at-rest encryption of TOTP
# secrets. If unset, a key is auto-generated and persisted to
# data/mfa.key. Generate with: openssl rand -hex 32
# MFA_ENCRYPTION_KEY=

# ── Stripe (web premium purchases) ──────────────────────────────
# Web checkout for FiHaven Pro. The server uses STRIPE_SECRET_KEY to
# create hosted Checkout sessions and verify webhooks; the publishable
# key is exposed to the browser via /api/billing/stripe/config.
# Use sk_test_/pk_test_ keys in dev to avoid real charges — if
# STRIPE_SECRET_KEY is unset, checkout falls back to a local dev-grant.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Recurring price IDs (price_…) created under your Stripe Product
# (Billing → Products). Each plan you set a price for is offered on the
# web paywall automatically; leave a line blank to hide that plan.
# The 7-day free trial is applied automatically at checkout (trial_period_days),
# so there is NO separate trial price. THREE_MONTH/TRIAL are optional legacy
# intervals — leave blank unless you deliberately offer them.
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
STRIPE_PRICE_FAMILY=
STRIPE_PRICE_THREE_MONTH=
STRIPE_PRICE_TRIAL=
# Signing secret from the webhook endpoint you register at
# {PUBLIC_ORIGIN}/fihaven/api/billing/stripe/webhook (Developers →
# Webhooks). Events: checkout.session.completed, customer.subscription.*,
# invoice.paid. If unset, webhook signatures are NOT verified (dev only).
STRIPE_WEBHOOK_SECRET=
# Public origin for Stripe success/cancel redirects (no trailing slash),
# e.g. https://fihaven.app. Falls back to the request host.
PUBLIC_ORIGIN=

# ── IndexNow (Bing, Yandex, etc.) ───────────────────────────────
# Optional. 8–128 hex chars; hosted at {PUBLIC_ORIGIN}/{key}.txt after
# build. Notifies search engines when you run npm run indexnow (also
# called automatically at the end of deploy when the key is set).
# Generate: openssl rand -hex 32
# INDEXNOW_KEY=

# ── Plaid (optional, Pro-gated bank linking) ────────────────────
# Bank syncing is a paid convenience overlay — the app works fully by
# hand without it. Get free Sandbox credentials at
# https://dashboard.plaid.com/signup (Team Settings → Keys).
# Leave the client_id/secret blank to keep the feature off (the UI then
# shows "not available on this server"). The access_token is stored
# encrypted at rest (AES-256-GCM, same key as MFA secrets).
#
# Your client_id is the SAME across environments; the secret is
# per-environment. You can use the generic names below, OR keep both
# environments' keys side by side with PLAID_SANDBOX_SECRET /
# PLAID_PRODUCTION_SECRET — the secret matching PLAID_ENV is used.
PLAID_CLIENT_ID=
PLAID_SECRET=
# PLAID_SANDBOX_SECRET=
# PLAID_PRODUCTION_SECRET=
# 'sandbox' (default, fake banks + test creds) or 'production'.
PLAID_ENV=sandbox
# Comma-separated Plaid products + ISO country codes.
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
# Optional: public HTTPS URL Plaid posts item/transactions webhooks to,
# e.g. https://fihaven.app/api/plaid/webhook. Needed for live updates.
PLAID_WEBHOOK_URL=
# Optional: OAuth redirect URI (must be allow-listed in the Plaid
# dashboard) for banks that use an OAuth handoff.
PLAID_REDIRECT_URI=

# ── Social sign-in (Sign in with Apple / Google) ────────────────
# Optional. A provider stays disabled until its audience(s) are set, so
# "Continue with …" buttons only appear once configured. Full setup
# walkthrough: docs/social-login-setup.md
#
# How tokens are verified. 'dev-trust' decodes the ID token WITHOUT
# checking its signature (local testing with hand-made tokens only);
# 'production' verifies the RS256 signature against the provider JWKS
# and validates iss/aud/exp. Defaults to production when NODE_ENV is
# production, else dev-trust.
# OAUTH_VERIFY_MODE=production
#
# Comma-separated allowed audiences (the "aud" claim). Google: the Web
# client id (web button) and the iOS client id. Android sign-in uses the
# WEB client id as its serverClientId, so Android tokens already carry the
# Web aud — don't add a separate Android client id here.
GOOGLE_OAUTH_CLIENT_ID=
# Apple: your Services ID (web button uses the FIRST entry) then the iOS app
# bundle id, e.g. app.fihaven.web,app.fihaven
APPLE_CLIENT_ID=

# ── Operations & admin ──────────────────────────────────────────
# Comma-separated admin emails (grants server-side admin routes in production).
# ADMIN_EMAILS=you@example.com
# Optional default recipient for deploy mail smoke tests (upload.sh / mail-check.js).
# MAIL_CHECK_TO=you@example.com
# Run bill-reminder + trial-ending scheduler in development (always on in production).
# ENABLE_SCHEDULER=1

# ── Sessions & dev helpers ──────────────────────────────────────
# Long-lived "remember this device" token lifetime (days). Default 30.
# TOKEN_TTL_DAYS=30
# Non-production only: seed a dev login user on startup.
# DEV_USER_EMAIL=dev@localhost
# DEV_USER_PASSWORD=changeme
# Tests only: alternate SQLite path (see server/db.js).
# FIHAVEN_TEST_DB_PATH=/tmp/fihaven-test.db
# Tests only: skip HTTP rate limiting.
# DISABLE_RATE_LIMIT=1

# ── In-app purchases (Apple / Google) ─────────────────────────────
# Override default product map (JSON: storeProductId -> {plan, days}). Usually
# leave unset — monthly/yearly/family are built in (see server/billing.js).
# IAP_PRODUCTS={"app.fihaven.pro.monthly":{"plan":"monthly","days":31},"app.fihaven.pro.yearly":{"plan":"yearly","days":366},"app.fihaven.pro.family":{"plan":"family","days":366}}
# 'dev-trust' skips store receipt verification (local only); 'production' verifies.
# IAP_VERIFY_MODE=production
# Set to 1 in production when Apple/Google receipt verification is wired.
# APPLE_VERIFY_ENABLED=1
# GOOGLE_VERIFY_ENABLED=1
# Play Developer API — path to the service-account JSON on the server
# (never commit the JSON). Package must match the Play listing.
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=/var/www/fihaven.app/data/google-play-sa.json
# GOOGLE_PLAY_PACKAGE=app.fihaven
# Local path to the JSON for upload.sh only (not deployed to the server .env).
# GOOGLE_PLAY_SA_LOCAL=/Users/you/Downloads/your-project-xxxxx.json
# Max household members for Pro / Family tiers (defaults 3 / 6).
# HOUSEHOLD_MAX_PRO=3
# HOUSEHOLD_MAX_FAMILY=6

# ── Remote push (APNs / FCM) ────────────────────────────────────
# Optional. When unset, the server skips push delivery (email + local
# notifications still work). Native apps register device tokens via
# POST /api/push/register when settings.pushNotifications is on.
#
# Apple Push Notification service (.p8 key from developer.apple.com):
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_KEY_PATH=/var/www/fihaven.app/data/apns-key.p8
# APNS_BUNDLE_ID=app.fihaven
# APNS_PRODUCTION=1
# Local path to the .p8 for upload.sh (not deployed verbatim).
# APNS_SA_LOCAL=/Users/you/Downloads/AuthKey_XXXXXXXXXX.p8
#
# Firebase Cloud Messaging (Firebase console → Project settings → Service accounts):
# FCM_SERVICE_ACCOUNT_JSON=/var/www/fihaven.app/data/firebase-sa.json
# FCM_SA_LOCAL=/Users/you/Downloads/fihaven-firebase-adminsdk-xxxxx.json
#
# Web Push (browser notifications, Chrome/Firefox/Edge). Generate a key pair
# with `npx web-push generate-vapid-keys`. When unset, the web "Enable browser
# notifications" button hides itself. Keep the private key secret.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:support@fihaven.app